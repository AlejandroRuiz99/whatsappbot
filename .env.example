# ────────────────────────────────────────────────────────────────
# Bot mode
# ────────────────────────────────────────────────────────────────
# sandbox | production
#   sandbox    → only processes messages from TEST_PHONE_NUMBER
#   production → processes all incoming non-broadcast messages
BOT_MODE=sandbox

# Required when BOT_MODE=sandbox. Country code + number, digits only.
TEST_PHONE_NUMBER=34XXXXXXXXX

# ────────────────────────────────────────────────────────────────
# LLM providers (at least ONE is required)
# ────────────────────────────────────────────────────────────────
# Groq — free tier, fast. Get a key at https://console.groq.com
# Must start with "gsk_". Placeholders are rejected at boot.
GROQ_API_KEY=

# OpenAI — also required if RAG is enabled (embeddings).
# Must start with "sk-". Placeholders are rejected at boot.
OPENAI_API_KEY=

# ────────────────────────────────────────────────────────────────
# Public URLs (must be valid in production)
# ────────────────────────────────────────────────────────────────
# Required in production. Placeholder rejected when BOT_MODE=production.
TELEGRAM_LINK=https://t.me/+XXXXX
BOOKING_URL=https://compromisolegal.es/reserva/

# ────────────────────────────────────────────────────────────────
# HTTP server
# ────────────────────────────────────────────────────────────────
PORT=3000

# ────────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────────
NODE_ENV=development
# debug | info | warn | error | bot
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────
# RAG / Vector database (Pinecone)
# RAG is disabled (with explicit boot log) if either OPENAI_API_KEY
# or PINECONE_API_KEY is missing.
# ────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=tiktok-despacho

# RAG tuning (optional, sane defaults applied)
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.7
RAG_VIDEO_THRESHOLD=0.75

# ────────────────────────────────────────────────────────────────
# Real human escalation (Telegram bot)
# Both must be set together to enable the Telegram transport;
# otherwise the bot falls back to console-only logging.
# Get a bot token from @BotFather, then add the bot to a group/chat
# and use the numeric chat ID (negative for groups).
# ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFICATION_CHAT_ID=
