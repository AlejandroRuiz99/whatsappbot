# WhatsApp / Baileys
# (Baileys genera credenciales automaticamente)

# Modo de operacion
BOT_MODE=sandbox  # sandbox | production
# En sandbox, solo procesa TEST_PHONE_NUMBER
TEST_PHONE_NUMBER=34XXXXXXXXX  # Tu numero para testing

# IA - Elige uno (Groq recomendado, es gratis)
# Groq: Obtén tu API key gratis en https://console.groq.com
GROQ_API_KEY=gsk_...

# OpenAI (opcional, de pago)
OPENAI_API_KEY=sk-...

# URLs
TELEGRAM_LINK=https://t.me/+XXXXX
BOOKING_URL=https://compromisolegal.es/reserva/

# Servidor web (UI de monitoreo)
PORT=3000

# Opcional
NODE_ENV=development
LOG_LEVEL=info

# RAG / Vector Database
# Pinecone: https://www.pinecone.io
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=tiktok-despacho

# RAG Configuration (opcional, valores por defecto)
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.7
RAG_VIDEO_THRESHOLD=0.75
